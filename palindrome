class Solution {
    public boolean isPalindrome(int x) {

        if (x < 0) {
            return false;
        }

        int n = x;
        int s = 0;

        while (x > 0) {
            int a = x % 10;
            s = s * 10 + a;
            x /= 10;
        }

        return n == s;
    }
}
//Palindrome number is a number in which the number is read the same when the numbers are reversed. In the first if condition we are checking that the number should not be negative.
//If it is negative then terminate it.Else in the next statements in the while loop we reverse the number and check if the number is same when reversed.
